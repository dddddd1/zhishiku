# LLM 配置
OPENAI_API_KEY=your_glm_api_key_here
OPENAI_BASE_URL=https://open.bigapi.cn/v1

# 兼容其他模型:
# DeepSeek: https://api.deepseek.com/v1
# 通义千问: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1

# 模型配置 (根据GLM免费模型调整)
MODEL_NAME=glm-4-flash
EMBEDDING_MODEL_NAME=embedding-2

# Upstash Redis (替代已废弃的 @vercel/kv)
# 通过 Vercel Marketplace 安装 Upstash Redis 后自动配置
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# 向后兼容: 如果仍使用 @vercel/kv,保留以下变量(不推荐)
# KV_URL=https://your-kv.upstash.io
# KV_REST_API_URL=https://your-kv.upstash.io
# KV_REST_API_TOKEN=your_kv_rest_api_token
# KV_REST_API_READ_ONLY_TOKEN=your_kv_read_only_token

# Vercel Blob
BLOB_READ_WRITE_TOKEN=your_blob_token

# 分块配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=3
